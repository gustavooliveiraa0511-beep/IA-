# ============================================
# COPIE ESTE ARQUIVO PARA .env E PREENCHA
# NUNCA COMITE O .env REAL (já está no .gitignore)
# ============================================

# === Telegram Bot ===
# Crie um bot com @BotFather no Telegram e pegue o token
TELEGRAM_BOT_TOKEN=
# Seu chat_id pessoal (pra filtrar — só você usa o bot)
# Descubra enviando /start e olhando no log
TELEGRAM_ALLOWED_CHAT_ID=

# === Groq (roteiro) ===
# Pegue em: https://console.groq.com/keys
GROQ_API_KEY=

# === Pexels (b-roll vídeos) ===
# Pegue em: https://www.pexels.com/api/
PEXELS_API_KEY=

# === Pixabay (imagens e sfx extras) ===
# Pegue em: https://pixabay.com/api/docs/
PIXABAY_API_KEY=

# === Cloudflare R2 (storage) ===
# Crie em: https://dash.cloudflare.com → R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=video-maker-bot
# URL pública (configurada no dashboard R2)
R2_PUBLIC_URL=

# === GitHub (pra bot disparar Actions) ===
# Token com permissão 'actions:write' no seu repo
# Pegue em: https://github.com/settings/tokens
GITHUB_TOKEN=
GITHUB_REPO=gustavooliveiraa0511-beep/IA-

# === Config opcional ===
DEFAULT_TEMPLATE=motivacional
DEFAULT_VOICE=pt-BR-AntonioNeural  # ou FranciscaNeural, ThalitaNeural
VIDEO_DURATION_SECONDS=30
