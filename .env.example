# ============================================================
# Dark Viral Video Generator - Configuração (100% GRATUITO)
# ============================================================
# Copie este arquivo para .env e preencha suas chaves
# NENHUMA chave é obrigatória — o app funciona sem elas!

# ─────────────────────────────────────────────────────────
# 🤖 OPCIONAL: Groq API — IA para gerar roteiros virais
# ─────────────────────────────────────────────────────────
# Grátis! Cadastre-se em: https://console.groq.com/
# Clique em "API Keys" → Create API Key
# Sem cartão de crédito, sem pagamento, 14.400 req/dia grátis
# Se deixar vazio: usa templates locais pré-prontos (também funciona!)
GROQ_API_KEY=gsk_SUA_CHAVE_AQUI

# ─────────────────────────────────────────────────────────
# 🎬 OPCIONAL: Pexels — imagens e vídeos HD reais nas cenas
# ─────────────────────────────────────────────────────────
# Grátis! Cadastre-se em: https://www.pexels.com/api/
# Se deixar vazio: usa backgrounds gerados (também funciona!)
PEXELS_API_KEY=SUA_CHAVE_PEXELS_AQUI

# ─────────────────────────────────────────────────────────
# 🖼️ OPCIONAL: Pixabay — alternativa ao Pexels
# ─────────────────────────────────────────────────────────
# Grátis! Cadastre-se em: https://pixabay.com/api/docs/
PIXABAY_API_KEY=SUA_CHAVE_PIXABAY_AQUI

# 🐛 Debug (true = mostra stack traces de erros)
DEBUG=false
